# --- Server ---
PORT=4000
NODE_ENV=development
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# --- Database / Cache ---
DATABASE_URL=postgresql://reviewer_user:reviewer_password@localhost:5432/ai_reviewer_db
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Crypto ---
# 32+ char secret for AES-256-GCM vault encryption
ENCRYPTION_KEY=
# Signing key for JWT auth cookies
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- GitHub ---
# OAuth App credentials for user login (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Shared bot token used to register webhooks and post PR review comments
GITHUB_ACCESS_TOKEN=
# Shared secret used to verify inbound webhook HMAC signatures
GITHUB_WEBHOOK_SECRET=

# --- AI provider model overrides (optional) ---
CLAUDE_MODEL=claude-sonnet-4-6
GROK_MODEL=grok-2-1212
GROK_BASE_URL=https://api.x.ai/v1
